NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
SERVICE_NAME=Auth_Service
LOG_LEVEL=info

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/yt_clone_auth?retryWrites=true&w=majority

# Use long random strings in production (e.g. openssl rand -hex 64)
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_secret
REFRESH_TOKEN_EXPIRY=7d
