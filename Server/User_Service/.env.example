NODE_ENV=development
PORT=3002
CLIENT_URL=http://localhost:5173
SERVICE_NAME=User_Service
LOG_LEVEL=info

# Same MongoDB cluster as Auth_Service, different DB name
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/yt_clone_users?retryWrites=true&w=majority

# Must match Auth_Service - used by verifyToken middleware to validate JWTs
ACCESS_TOKEN_SECRET=replace_with_same_secret_as_auth_service
